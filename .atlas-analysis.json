  "keyFeatures": [
    "Multi-site financial dashboard with KPI tracking and trend analysis",
    "Transaction management with income, expense, and refund categorization",
    "Inventory management with offline-first sync and consumption tracking",
    "Production log tracking per mining site",
    "Team management with shift scheduling and timesheet tracking",
    "Safety incident reporting and resolution tracking",
    "Equipment maintenance and service scheduling",
    "Supply chain management (suppliers, channels, purchase orders)",
    "Customer CRM with profitability reporting",
    "PDF and CSV report exports",
    "Offline-first architecture with background sync engine",
    "Multi-tenant organization and role-based access control"
  ],
  "publicApiSurface": [
    "getTransactions(siteId, filters?)",
    "createTransaction(siteId, payload, createdBy?)",
    "getInventoryItems(siteId)",
    "createInventoryItem(siteId, payload)",
    "consumeInventoryItem(siteId, item, qty, opts?)",
    "writeOffInventoryItem(siteId, item, qty, reason, notes, userId?)",
    "getSafetyIncidents(siteId)",
    "getEquipment(siteId)",
    "getWorkers(siteId)",
    "getPlannedShifts(siteId, from, to)",
    "getKpiTargets(siteId, months)",
    "getMonthlyTrend(siteId, from, to)",
    "getExpensesByCategory(siteId, from, to, customerId?)",
    "getIncomeByCategory(siteId, from, to, customerId?)",
    "getCustomerSummaries(siteId, from, to)",
    "initSyncEngine()",
    "drainQueue(onProgress?)",
    "registerHandler(entity, operation, fn)",
    "useOrgModules()",
    "usePendingCount()",
    "useSyncLog(limit?)"
  ]
